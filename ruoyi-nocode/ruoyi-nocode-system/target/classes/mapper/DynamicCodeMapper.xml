<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.nocode.system.mapper.DynamicCodeMapper">

    <resultMap type="com.ruoyi.nocode.system.entity.DynamicCode" id="DynamicCodeResult">
        <id property="codeId" column="code_id"/>
        <result property="codeCode" column="code_code"/>
        <result property="codeName" column="code_name"/>
        <result property="pluginId" column="plugin_id"/>
        <result property="className" column="class_name"/>
        <result property="packageName" column="package_name"/>
        <result property="sourceCode" column="source_code"/>
        <result property="compiledBytes" column="compiled_bytes"/>
        <result property="codeType" column="code_type"/>
        <result property="codeVersion" column="code_version"/>
        <result property="status" column="status"/>
        <result property="enabled" column="enabled"/>
        <result property="sandboxMode" column="sandbox_mode"/>
        <result property="securityConfig" column="security_config"/>
        <result property="dependencies" column="dependencies"/>
        <result property="lastCompileTime" column="last_compile_time"/>
        <result property="compileError" column="compile_error"/>
        <result property="executeCount" column="execute_count"/>
        <result property="lastExecuteTime" column="last_execute_time"/>
        <result property="lastResult" column="last_result"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectDynamicCodeVo">
        select code_id, code_code, code_name, plugin_id, class_name, package_name, source_code, compiled_bytes,
               code_type, code_version, status, enabled, sandbox_mode, security_config, dependencies,
               last_compile_time, compile_error, execute_count, last_execute_time, last_result,
               create_by, create_time, update_by, update_time, remark, del_flag
        from nocode_dynamic_code
    </sql>

    <select id="selectByCodeCode" parameterType="String" resultMap="DynamicCodeResult">
        <include refid="selectDynamicCodeVo"/>
        where code_code = #{codeCode} and del_flag = '0'
    </select>

    <select id="selectByClassName" parameterType="String" resultMap="DynamicCodeResult">
        <include refid="selectDynamicCodeVo"/>
        where class_name = #{className} and del_flag = '0'
    </select>

    <select id="selectEnabledCodes" resultMap="DynamicCodeResult">
        <include refid="selectDynamicCodeVo"/>
        where enabled = true and status = 'COMPILED' and del_flag = '0'
        order by update_time desc
    </select>

    <select id="selectByPluginId" parameterType="Long" resultMap="DynamicCodeResult">
        <include refid="selectDynamicCodeVo"/>
        where plugin_id = #{pluginId} and del_flag = '0'
        order by update_time desc
    </select>

    <select id="selectByStatus" parameterType="String" resultMap="DynamicCodeResult">
        <include refid="selectDynamicCodeVo"/>
        where status = #{status} and del_flag = '0'
        order by update_time desc
    </select>

    <select id="checkCodeCodeUnique" resultMap="DynamicCodeResult">
        <include refid="selectDynamicCodeVo"/>
        where code_code = #{codeCode} and del_flag = '0'
        <if test="codeId != null">
            and code_id != #{codeId}
        </if>
        limit 1
    </select>

    <select id="checkClassNameUnique" resultMap="DynamicCodeResult">
        <include refid="selectDynamicCodeVo"/>
        where class_name = #{className} and del_flag = '0'
        <if test="codeId != null">
            and code_id != #{codeId}
        </if>
        limit 1
    </select>

    <update id="incrementExecuteCount" parameterType="Long">
        update nocode_dynamic_code
        set execute_count = execute_count + 1,
            last_execute_time = CURRENT_TIMESTAMP
        where code_id = #{codeId}
    </update>

</mapper>
